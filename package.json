    "gatsby-source-filesystem": "^5.16.0",
    "gatsby-transformer-json": "^5.16.0",
    "gatsby-transformer-sharp": "^5.16.0",
    "i18next": "^23.16.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^15.0.0",
    "react-icons": "^4.4.0",
    "styled-components": "^5.3.5"
